# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/change_db"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="change_db"

# Redis
REDIS_URL="redis://localhost:6379"
# Set a strong password in production; leave empty for local dev without auth
REDIS_PASSWORD=""

# JWT
JWT_SECRET="change-this-to-a-secure-random-string"
JWT_EXPIRES_IN="7d"

# App
NODE_ENV="development"
API_PORT=3001
WEB_PORT=3000
# Public URLs (used in links, emails, og tags)
APP_URL="http://localhost:3000"
API_URL="http://localhost:3001"
# Logging: error | warn | info | debug | verbose
LOG_LEVEL="info"
# Set to true to seed the DB on container start (development only)
SEED_ON_START="false"

# CORS
CORS_ORIGINS="http://localhost:3000"

# Next.js (public)
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# Payment Gateway
# Set to 'mock' for local dev, 'toss' for production
PAYMENT_PROVIDER="mock"

# Toss Payments (required when PAYMENT_PROVIDER=toss)
# Get keys from https://developers.tosspayments.com
TOSS_CLIENT_KEY=""
TOSS_SECRET_KEY=""
TOSS_WEBHOOK_SECRET=""
TOSS_SUCCESS_URL="http://localhost:3000/donations/success"
TOSS_FAIL_URL="http://localhost:3000/donations/fail"
